---
const items = [
  {
    color: "var(--warning)",
    title: "Integrated SFTP, drag &amp; drop",
    body: "Browse the remote filesystem in a sidebar and drag files in either direction over the same SSH channel — no separate SFTP client, no re-auth.",
    icon: `<path d="M4 7a2 2 0 0 1 2-2h4l2 2h6a2 2 0 0 1 2 2v8a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V7Z" stroke="currentColor" stroke-width="1.8" stroke-linejoin="round"/>`,
  },
  {
    color: "var(--info)",
    title: "ProxyJump &amp; bastion hosts, built in",
    body: "Production boxes usually sit behind a jump host. Configure a ProxyJump chain once and each hop authenticates independently, exactly like your <code class=\"mono\">~/.ssh/config</code> already expects — same tmux persistence guarantees end-to-end.",
    icon: `<rect x="2.5" y="9.5" width="5" height="5" rx="1" stroke="currentColor" stroke-width="1.8"/><rect x="9.5" y="3" width="5" height="5" rx="1" stroke="currentColor" stroke-width="1.8"/><rect x="16.5" y="16" width="5" height="5" rx="1" stroke="currentColor" stroke-width="1.8"/><path d="M7.5 10.8 11 6.6M13.5 7.4 17.5 15.8" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-dasharray="1 3.2"/><path d="M16.4 14.4l1.4 1.9-2.2 0.9" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>`,
  },
  {
    color: "var(--info)",
    title: "macOS today",
    body: "Shipping now for macOS on Apple Silicon, built as a native Tauri app — small footprint, fast startup, no Electron bloat.",
    icon: `<rect x="4" y="4" width="16" height="12" rx="2" stroke="currentColor" stroke-width="1.8"/><path d="M9 20h6M12 16v4" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>`,
  },
];
---

<section class="secondary">
  <div class="wrap">
    <div class="secondary-grid">
      {items.map((item, i) => (
        <div class={`sec-card reveal reveal-delay-${i + 1}`}>
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" style={`color:${item.color}`} set:html={item.icon} />
          <h3 set:html={item.title} />
          <p set:html={item.body} />
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .secondary {
    padding-top: 0;
    padding-bottom: 40px;
  }
  .secondary-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 22px;
  }
  @media (max-width: 860px) {
    .secondary-grid { grid-template-columns: 1fr; }
  }
  .sec-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 14px;
    padding: 24px;
  }
  .sec-card svg { margin-bottom: 14px; }
  .sec-card h3 {
    font-size: 16.5px;
    margin: 0 0 8px;
    font-weight: 700;
  }
  .sec-card p {
    font-size: 14px;
    color: var(--muted);
    margin: 0;
    line-height: 1.6;
  }
</style>

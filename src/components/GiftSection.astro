---
import { RELEASE } from "../lib/release.ts";
---

<section class="gift">
  <div class="wrap gift-inner reveal">
    <h2>A gift from State Change.</h2>
    <p>
      Smart Terminal is built and given away by <a href="https://statechange.ai" target="_blank" rel="noopener noreferrer" class="sc-link">State Change</a>, free to use, no account required. We build tools we want to exist — this is one of them.
    </p>
    <div class="gift-cta">
      <a class="btn btn-primary" href={RELEASE.dmgUrl}>Download Smart Terminal</a>
      <a class="btn btn-ghost" href="https://statechange.ai" target="_blank" rel="noopener noreferrer">
        Visit statechange.ai →
      </a>
    </div>
  </div>
</section>

<style>
  .gift {
    background: linear-gradient(160deg, var(--surface) 0%, var(--bg) 60%);
    border-top: 1px solid var(--border);
  }
  .gift-inner {
    text-align: center;
    max-width: 640px;
  }
  .gift h2 {
    font-size: clamp(26px, 3.6vw, 36px);
    margin: 0 0 16px;
    font-weight: 800;
  }
  .gift p {
    color: var(--muted);
    font-size: 16.5px;
    margin: 0 0 32px;
  }
  .sc-link {
    color: var(--accent-text);
    font-weight: 600;
    text-decoration: underline;
    text-decoration-color: rgba(231, 182, 90, 0.4);
    text-underline-offset: 3px;
  }
  .sc-link:hover {
    text-decoration-color: var(--accent-text);
  }
  .gift-cta {
    display: flex;
    gap: 14px;
    justify-content: center;
    flex-wrap: wrap;
  }
</style>

---
import { RELEASE } from "../lib/release.ts";
---

<header class="hero">
  <div class="wrap hero-grid">
    <div class="hero-copy">
      <div class="kicker">
        <span class="dot"></span>
        tmux control-mode, natively rendered
      </div>
      <h1>
        The SSH terminal that
        <span class="accent-text">never forgets</span>
        your session.
      </h1>
      <p class="lede">
        Smart Terminal keeps every pane alive through disconnects, sleep, and
        crashes — reconnect and pick up exactly where you left off. Built on
        real tmux control mode, not a reimplementation.
      </p>

      <div class="cta-row">
        <a class="btn btn-primary" href={RELEASE.dmgUrl}>
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M12 3v12m0 0-4-4m4 4 4-4M5 21h14" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          Download for Mac
        </a>
        <a class="btn btn-ghost" href="#features">See how it works</a>
      </div>
      <div class="cta-meta">
        v{RELEASE.version} · Apple Silicon · free, no account required
      </div>
    </div>

    <div class="hero-term reveal">
      <div class="term-chrome">
        <div class="term-dots">
          <span style="background:#ff9d8a"></span>
          <span style="background:#e7b65a"></span>
          <span style="background:#9ed17a"></span>
        </div>
        <div class="term-title mono">ray@cronmaster — smart-terminal</div>
      </div>
      <pre class="term-body mono" id="hero-typer" aria-hidden="true"></pre>
    </div>
  </div>
</header>

<style>
  .hero {
    padding: 120px 0 60px;
    overflow: hidden;
    position: relative;
  }
  .hero::before {
    content: "";
    position: absolute;
    top: -200px;
    left: 50%;
    width: 900px;
    height: 500px;
    transform: translateX(-50%);
    background: radial-gradient(closest-side, rgba(213, 154, 74, 0.25), transparent 70%);
    pointer-events: none;
  }
  .hero-grid {
    display: grid;
    grid-template-columns: 1.05fr 1fr;
    gap: 56px;
    align-items: center;
    position: relative;
  }
  @media (max-width: 940px) {
    .hero-grid {
      grid-template-columns: 1fr;
    }
  }
  .kicker {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 0.04em;
    color: var(--accent-text);
    background: rgba(213, 154, 74, 0.1);
    border: 1px solid rgba(213, 154, 74, 0.3);
    padding: 6px 14px;
    border-radius: 999px;
    margin-bottom: 22px;
  }
  .dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: var(--success);
    box-shadow: 0 0 8px var(--success);
    animation: pulse 2s ease-in-out infinite;
  }
  @keyframes pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.35; }
  }
  h1 {
    font-size: clamp(34px, 5vw, 56px);
    line-height: 1.08;
    font-weight: 800;
    letter-spacing: -0.02em;
    margin: 0 0 22px;
  }
  .accent-text {
    color: var(--accent-text);
    background: linear-gradient(180deg, transparent 62%, rgba(213, 154, 74, 0.28) 62%);
  }
  .lede {
    font-size: 19px;
    color: var(--muted);
    max-width: 540px;
    margin: 0 0 34px;
  }
  .cta-row {
    display: flex;
    gap: 14px;
    flex-wrap: wrap;
  }
  .cta-meta {
    margin-top: 14px;
    font-size: 13px;
    color: var(--muted);
  }

  .hero-term {
    background: var(--sidebar);
    border: 1px solid var(--border);
    border-radius: 14px;
    overflow: hidden;
    box-shadow: var(--shadow-amber), 0 40px 80px -30px rgba(0,0,0,0.6);
  }
  .term-chrome {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 12px 16px;
    background: var(--surface);
    border-bottom: 1px solid var(--border);
  }
  .term-dots {
    display: flex;
    gap: 7px;
  }
  .term-dots span {
    width: 11px;
    height: 11px;
    border-radius: 50%;
    display: inline-block;
  }
  .term-title {
    font-size: 12.5px;
    color: var(--muted);
  }
  .term-body {
    margin: 0;
    padding: 22px 20px 28px;
    font-size: 14px;
    line-height: 1.75;
    min-height: 300px;
    white-space: pre-wrap;
    color: var(--text);
  }
</style>

<script>
  type Segment = { text: string; cls?: string; pause?: number };

  const lines: Segment[][] = [
    [{ text: "$ ", cls: "muted" }, { text: "ssh cronmaster" }],
    [{ text: "  tmux control mode attached — 3 panes restored", cls: "success" }],
    [{ text: "  session alive for 14h22m across 2 disconnects", cls: "muted" }],
    [{ text: "" }],
    [{ text: "$ ", cls: "muted" }, { text: "st agent: " }, { text: "\"deploy check\"", cls: "agent" }],
    [{ text: "  ▸ running pre-flight checks…", cls: "agent" }],
    [{ text: "  ✓ tests green, lockfile clean, no drift", cls: "success" }],
    [{ text: "" }],
    [{ text: "$ ", cls: "muted" }, { text: "[disconnect — laptop sleeps]", cls: "danger" }, { pause: 650 }],
    [{ text: "[reconnect]", cls: "info" }],
    [{ text: "  ● resumed exactly where you left off", cls: "success" }],
  ];

  const el = document.getElementById("hero-typer");
  if (el && !window.matchMedia("(prefers-reduced-motion: reduce)").matches) {
    let mounted = true;
    (async () => {
      while (mounted) {
        el.innerHTML = "";
        for (const line of lines) {
          const lineEl = document.createElement("div");
          el.appendChild(lineEl);
          for (const seg of line) {
            if (seg.pause) {
              await sleep(seg.pause);
              continue;
            }
            const span = document.createElement("span");
            if (seg.cls) span.className = `tk-${seg.cls}`;
            lineEl.appendChild(span);
            for (const ch of seg.text) {
              if (!mounted) return;
              span.textContent += ch;
              await sleep(14 + Math.random() * 18);
            }
          }
        }
        await sleep(2200);
      }
    })();
    window.addEventListener("beforeunload", () => (mounted = false));
  } else if (el) {
    el.textContent = lines.map((l) => l.map((s) => s.text).join("")).join("\n");
  }

  function sleep(ms: number) {
    return new Promise((r) => setTimeout(r, ms));
  }
</script>

<style is:global>
  .tk-muted { color: var(--muted); }
  .tk-success { color: var(--success); }
  .tk-danger { color: var(--danger); }
  .tk-info { color: var(--info); }
  .tk-agent { color: var(--agent); }
</style>

---
import { RELEASE } from "../lib/release.ts";
---

<header class="hero">
  <canvas class="grid-hero" aria-hidden="true"></canvas>
  <div class="hero-scrim" aria-hidden="true"></div>
  <div class="wrap hero-grid">
    <div class="hero-copy">
      <div class="brand-row">
        <img src="/icon.png" width="30" height="30" alt="" class="brand-icon" />
        <span class="brand-word">Smart Terminal</span>
      </div>
      <h1>The SSH terminal that <span class="accent-text">never forgets</span> your session.</h1>
      <p class="lede">
        Smart Terminal keeps every pane alive through disconnects, sleep, and
        crashes — reconnect and pick up exactly where you left off. Built on
        real tmux control mode, not a reimplementation.
      </p>

      <div class="cta-row">
        <a class="btn btn-primary" href={RELEASE.dmgUrl}>
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M12 3v12m0 0-4-4m4 4 4-4M5 21h14" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          Download for Mac
        </a>
        <a class="btn btn-ghost" href="#features">See how it works</a>
      </div>
      <div class="cta-meta">
        v{RELEASE.version} · Apple Silicon · free, no account required
      </div>
    </div>

    <div class="hero-shot reveal">
      <img
        src="/screenshots/connect-screen.png"
        width="2400"
        height="1600"
        alt="Smart Terminal's connect screen: a saved SSH profile with a ProxyJump bastion-host checkbox and a 'Wrap in tmux session' option"
        class="hero-shot-img"
      />
    </div>
  </div>
</header>

<style>
  .hero {
    padding: 120px 0 60px;
    overflow: hidden;
    position: relative;
  }
  .hero::before {
    content: "";
    position: absolute;
    top: -200px;
    left: 50%;
    width: 900px;
    height: 500px;
    transform: translateX(-50%);
    background: radial-gradient(closest-side, rgba(213, 154, 74, 0.25), transparent 70%);
    pointer-events: none;
  }
  .grid-hero {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    display: block;
    z-index: 0;
  }
  /* WebGL unavailable → grid-field.js adds .grid-fallback: static amber glow. */
  .grid-hero.grid-fallback {
    background: radial-gradient(900px 500px at 50% 30%, rgba(213, 154, 74, 0.14), transparent 68%);
  }
  .hero-scrim {
    position: absolute;
    inset: 0;
    z-index: 1;
    pointer-events: none;
    background: radial-gradient(900px 560px at 28% 45%, var(--bg) 0%, rgba(42, 32, 24, 0.7) 46%, transparent 78%);
  }
  .hero-grid {
    display: grid;
    grid-template-columns: 1.05fr 1fr;
    gap: 56px;
    align-items: center;
    position: relative;
    z-index: 2;
  }
  @media (max-width: 940px) {
    .hero-grid {
      grid-template-columns: 1fr;
    }
  }
  .brand-row {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 26px;
  }
  .brand-icon {
    border-radius: 8px;
    display: block;
  }
  .brand-word {
    font-size: 15px;
    font-weight: 600;
    color: var(--muted);
    letter-spacing: 0.01em;
  }
  h1 {
    font-size: clamp(34px, 5vw, 56px);
    line-height: 1.08;
    font-weight: 800;
    letter-spacing: -0.02em;
    margin: 0 0 22px;
  }
  .accent-text {
    color: var(--accent-text);
    background: linear-gradient(180deg, transparent 62%, rgba(213, 154, 74, 0.28) 62%);
  }
  .lede {
    font-size: 19px;
    color: var(--muted);
    max-width: 540px;
    margin: 0 0 34px;
  }
  .cta-row {
    display: flex;
    gap: 14px;
    flex-wrap: wrap;
  }
  .cta-meta {
    margin-top: 14px;
    font-size: 13px;
    color: var(--muted);
  }

  .hero-shot {
    background: var(--sidebar);
    border: 1px solid var(--border);
    border-radius: 14px;
    overflow: hidden;
    box-shadow: var(--shadow-amber), 0 40px 80px -30px rgba(0,0,0,0.6);
    animation: hero-float 7s ease-in-out infinite;
  }
  .hero-shot-img {
    display: block;
    width: 100%;
    height: auto;
  }
  @keyframes hero-float {
    0%, 100% { transform: translateY(0) rotate(0deg); }
    50% { transform: translateY(-10px) rotate(-0.25deg); }
  }
  @media (prefers-reduced-motion: reduce) {
    .hero-shot {
      animation: none;
    }
  }
</style>

<script src="/grid-field.js" is:inline></script>

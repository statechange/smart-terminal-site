---
const panels = [
  { id: "blocks", label: "Block-primary mode" },
  { id: "panes", label: "Native tmux panes" },
  { id: "sftp", label: "SFTP drag &amp; drop" },
  { id: "agent", label: "AI agent feed" },
];
---

<section class="mockups">
  <div class="wrap">
    <p class="section-eyebrow reveal">Inside the app</p>
    <h2 class="section-title reveal">A terminal that renders like a modern app.</h2>
    <p class="section-sub reveal">
      Every pane is real tmux underneath — but the chrome is a modern desktop app.
      These panels are code-recreated mockups of app screens, drawn in the
      exact app palette.
    </p>

    <div class="mock-tabs reveal" role="tablist">
      {panels.map((p, i) => (
        <button class="mock-tab" data-target={p.id} aria-selected={i === 0 ? "true" : "false"} set:html={p.label} />
      ))}
    </div>

    <div class="mock-stage reveal">
      <!-- Block-primary mode -->
      <div class="mock-panel is-active" data-panel="blocks">
        <div class="app-chrome">
          <div class="term-chrome">
            <div class="term-dots"><span style="background:#ff9d8a"></span><span style="background:#e7b65a"></span><span style="background:#9ed17a"></span></div>
            <div class="term-title mono">cronmaster — block mode</div>
          </div>
          <div class="block-list mono">
            <div class="cmd-block">
              <div class="block-head"><span class="status-dot ok"></span><span class="block-cmd">pnpm build</span><span class="block-time">4.2s</span></div>
              <div class="block-out ok-out">✓ built in 4.2s — dist/ 218 modules</div>
            </div>
            <div class="cmd-block">
              <div class="block-head"><span class="status-dot ok"></span><span class="block-cmd">git status -sb</span><span class="block-time">0.1s</span></div>
              <div class="block-out">## main...origin/main<br/>M  src/lib/release.ts</div>
            </div>
            <div class="cmd-block">
              <div class="block-head"><span class="status-dot run"></span><span class="block-cmd">cargo test --workspace</span><span class="block-time">running…</span></div>
              <div class="block-out">running 42 tests<br/>test ssh::session::reconnect ... ok</div>
            </div>
            <div class="cmd-block">
              <div class="block-head"><span class="status-dot err"></span><span class="block-cmd">./deploy.sh --check</span><span class="block-time">1.1s</span></div>
              <div class="block-out err-out">✗ lockfile drift detected — run pnpm install</div>
            </div>
          </div>
        </div>
      </div>

      <!-- Native tmux panes -->
      <div class="mock-panel" data-panel="panes">
        <div class="app-chrome">
          <div class="term-chrome">
            <div class="term-dots"><span style="background:#ff9d8a"></span><span style="background:#e7b65a"></span><span style="background:#9ed17a"></span></div>
            <div class="term-title mono">cronmaster — 3 panes, tmux -CC</div>
          </div>
          <div class="pane-grid">
            <div class="tmux-pane pane-a mono">
              <div class="pane-label">%0 · logs</div>
              <div class="pane-body muted">
                10:41:02 GET /health 200 4ms<br/>
                10:41:03 GET /api/session 200 12ms<br/>
                10:41:05 GET /health 200 3ms<br/>
                <span class="cursor-blink">▌</span>
              </div>
            </div>
            <div class="tmux-pane pane-b mono">
              <div class="pane-label">%1 · editor</div>
              <div class="pane-body">
                <span class="tk-info">12</span> fn reconnect(&self) {'{'}<br/>
                <span class="tk-info">13</span>&nbsp;&nbsp;self.tmux.attach_cc()?;<br/>
                <span class="tk-info">14</span>&nbsp;&nbsp;<span class="tk-success">Ok(())</span><br/>
                <span class="tk-info">15</span> {'}'}
              </div>
            </div>
            <div class="tmux-pane pane-c mono">
              <div class="pane-label">%2 · shell</div>
              <div class="pane-body">
                $ tmux ls<br/>
                main: 3 windows (attached)<br/>
                $ <span class="cursor-blink">▌</span>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- SFTP -->
      <div class="mock-panel" data-panel="sftp">
        <div class="app-chrome">
          <div class="term-chrome">
            <div class="term-dots"><span style="background:#ff9d8a"></span><span style="background:#e7b65a"></span><span style="background:#9ed17a"></span></div>
            <div class="term-title mono">cronmaster — files</div>
          </div>
          <div class="sftp-layout">
            <div class="file-tree mono">
              <div class="tree-row folder open">▾ smart-terminal/</div>
              <div class="tree-row folder open indent1">▾ src/</div>
              <div class="tree-row indent2">lib.rs</div>
              <div class="tree-row indent2 dragging">session.rs</div>
              <div class="tree-row folder indent1">▸ scripts/</div>
              <div class="tree-row">Cargo.toml</div>
              <div class="tree-row">README.md</div>
            </div>
            <div class="drop-zone">
              <div class="drop-ghost mono">session.rs</div>
              <svg width="26" height="26" viewBox="0 0 24 24" fill="none">
                <path d="M12 3v13m0 0-4.5-4.5M12 16l4.5-4.5M4 21h16" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
              <span>Drop to upload to <code class="mono">/home/ray/app</code></span>
            </div>
          </div>
        </div>
      </div>

      <!-- Agent feed -->
      <div class="mock-panel" data-panel="agent">
        <div class="app-chrome">
          <div class="term-chrome">
            <div class="term-dots"><span style="background:#ff9d8a"></span><span style="background:#e7b65a"></span><span style="background:#9ed17a"></span></div>
            <div class="term-title mono">cronmaster — agent feed</div>
          </div>
          <div class="agent-feed">
            <div class="agent-msg">
              <span class="agent-badge">agent</span>
              <p>Checked out <code class="mono">fix/reconnect-race</code> and reran the failing suite — 2 tests fixed, 1 still red in <code class="mono">ssh::session</code>.</p>
            </div>
            <div class="agent-cmd mono">
              <span class="tk-muted">$</span> cargo test session::reconnect -- --nocapture
            </div>
            <div class="agent-msg">
              <span class="agent-badge">agent</span>
              <p>Root cause: reconnect races the tmux control-mode handshake. Proposing a fix — want me to apply it?</p>
            </div>
            <div class="smart-input mono">
              <span class="tk-muted">›</span>
              <span class="typed-text">yes, apply and run tests again</span>
              <span class="cursor-blink">▌</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .mock-tabs {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
    margin-bottom: 24px;
  }
  .mock-tab {
    font-family: var(--font-sans);
    font-size: 14px;
    font-weight: 600;
    color: var(--muted);
    background: var(--surface);
    border: 1px solid var(--border);
    padding: 10px 18px;
    border-radius: 999px;
    cursor: pointer;
    transition: all 0.15s ease;
  }
  .mock-tab:hover {
    color: var(--text);
    border-color: var(--accent-text);
  }
  .mock-tab[aria-selected="true"] {
    background: var(--accent);
    color: var(--accent-fg);
    border-color: var(--accent);
  }

  .mock-stage {
    position: relative;
  }
  .mock-panel {
    display: none;
    animation: fadeIn 0.35s ease;
  }
  .mock-panel.is-active {
    display: block;
  }
  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(6px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .app-chrome {
    border-radius: 16px;
    overflow: hidden;
    border: 1px solid var(--border);
    background: var(--sidebar);
    box-shadow: 0 40px 90px -30px rgba(0,0,0,0.65), var(--shadow-amber);
  }
  .term-chrome {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 12px 16px;
    background: var(--surface);
    border-bottom: 1px solid var(--border);
  }
  .term-dots { display: flex; gap: 7px; }
  .term-dots span { width: 11px; height: 11px; border-radius: 50%; display: inline-block; }
  .term-title { font-size: 12.5px; color: var(--muted); }

  /* Block-primary */
  .block-list { padding: 18px; display: grid; gap: 12px; min-height: 380px; }
  .cmd-block {
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: 10px;
    overflow: hidden;
  }
  .block-head {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 10px 14px;
    background: var(--surface);
    font-size: 13.5px;
  }
  .status-dot { width: 9px; height: 9px; border-radius: 50%; flex: none; }
  .status-dot.ok { background: var(--success); box-shadow: 0 0 6px var(--success); }
  .status-dot.err { background: var(--danger); box-shadow: 0 0 6px var(--danger); }
  .status-dot.run { background: var(--warning); box-shadow: 0 0 6px var(--warning); animation: pulse 1.4s ease-in-out infinite; }
  @keyframes pulse { 0%,100%{opacity:1} 50%{opacity:0.4} }
  .block-cmd { flex: 1; color: var(--text); }
  .block-time { color: var(--muted); font-size: 12px; }
  .block-out { padding: 10px 14px; font-size: 13px; color: var(--muted); line-height: 1.6; }
  .ok-out { color: var(--success); }
  .err-out { color: var(--danger); }

  /* Panes */
  .pane-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    grid-template-rows: 1fr 1fr;
    gap: 2px;
    background: var(--border);
    min-height: 380px;
  }
  .pane-a { grid-row: 1 / 3; }
  .tmux-pane { background: var(--bg); padding: 14px; display: flex; flex-direction: column; gap: 8px; }
  .pane-label { font-size: 11px; color: var(--accent-text); text-transform: uppercase; letter-spacing: 0.06em; }
  .pane-body { font-size: 13px; line-height: 1.7; color: var(--text); }
  .muted { color: var(--muted); }
  .cursor-blink { animation: blink 1s step-end infinite; color: var(--accent-text); }
  @keyframes blink { 50% { opacity: 0; } }

  /* SFTP */
  .sftp-layout {
    display: grid;
    grid-template-columns: 260px 1fr;
    min-height: 380px;
  }
  .file-tree {
    border-right: 1px solid var(--border);
    padding: 16px 10px;
    font-size: 13.5px;
  }
  .tree-row { padding: 5px 10px; border-radius: 6px; color: var(--text); cursor: default; }
  .tree-row.folder { color: var(--accent-text); font-weight: 600; }
  .tree-row.indent1 { padding-left: 24px; }
  .tree-row.indent2 { padding-left: 38px; color: var(--muted); }
  .tree-row.dragging { background: rgba(213,154,74,0.18); outline: 1px dashed var(--accent-text); color: var(--accent-text); }
  .drop-zone {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 12px;
    margin: 20px;
    border: 2px dashed var(--border);
    border-radius: 12px;
    color: var(--muted);
    font-size: 14px;
    position: relative;
  }
  .drop-zone code { background: rgba(0,0,0,0.25); padding: 1px 6px; border-radius: 5px; color: var(--accent-text); }
  .drop-ghost {
    position: absolute;
    top: 24px;
    left: 50%;
    transform: translateX(-50%) rotate(-2deg);
    background: var(--surface);
    border: 1px solid var(--accent);
    color: var(--accent-text);
    padding: 5px 12px;
    border-radius: 7px;
    font-size: 12.5px;
    box-shadow: 0 8px 20px -6px rgba(0,0,0,0.5);
  }

  /* Agent feed */
  .agent-feed { padding: 20px; display: flex; flex-direction: column; gap: 14px; min-height: 380px; }
  .agent-msg { background: rgba(215, 163, 224, 0.08); border: 1px solid rgba(215, 163, 224, 0.28); border-radius: 10px; padding: 12px 14px; }
  .agent-badge {
    display: inline-block;
    font-size: 10.5px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--agent);
    background: rgba(215,163,224,0.14);
    border-radius: 999px;
    padding: 2px 9px;
    margin-bottom: 8px;
  }
  .agent-msg p { margin: 0; font-size: 14px; color: var(--text); line-height: 1.6; }
  .agent-msg code { background: rgba(0,0,0,0.25); padding: 1px 5px; border-radius: 4px; color: var(--accent-text); font-size: 0.9em; }
  .agent-cmd { font-size: 13px; color: var(--text); padding: 8px 14px; background: var(--bg); border: 1px solid var(--border); border-radius: 8px; }
  .smart-input {
    margin-top: auto;
    display: flex;
    align-items: center;
    gap: 8px;
    background: var(--bg);
    border: 1px solid var(--accent);
    border-radius: 10px;
    padding: 12px 14px;
    font-size: 14px;
  }
  .typed-text { color: var(--text); }
</style>

<script>
  const tabs = document.querySelectorAll<HTMLButtonElement>(".mock-tab");
  const panels = document.querySelectorAll<HTMLDivElement>(".mock-panel");
  tabs.forEach((tab) => {
    tab.addEventListener("click", () => {
      tabs.forEach((t) => t.setAttribute("aria-selected", "false"));
      tab.setAttribute("aria-selected", "true");
      const target = tab.dataset.target;
      panels.forEach((p) => p.classList.toggle("is-active", p.dataset.panel === target));
    });
  });
</script>
